{
  "name": "@launchapp-dev/animus-trigger-discord",
  "version": "0.1.1",
  "description": "Discord trigger plugin for Animus — emits TriggerEvents for mentions + DMs, exposes outbound RPC for channel/DM/embed sends.",
  "license": "Elastic-2.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "animus-trigger-discord": "./dist/index.cjs"
  },
  "files": [
    "dist",
    "scripts",
    "src",
    "tsup.config.ts",
    "tsconfig.json",
    "tsconfig.build.json",
    "plugin.toml",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "postinstall": "node scripts/build-sdk-if-needed.mjs",
    "prepare": "node scripts/prepare-dist.mjs",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "node dist/index.cjs",
    "manifest": "node dist/index.cjs --manifest"
  },
  "dependencies": {
    "@launchapp-dev/animus-plugin-sdk": "github:launchapp-dev/animus-plugin-sdk-ts#v0.1.1",
    "discord.js": "^14.16.3"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^1.6.0"
  }
}
